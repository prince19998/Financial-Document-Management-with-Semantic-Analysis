{
  "name": "financial-document-intelligence",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n BACKEND,FRONTEND -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "cd backend && .\\Nimapenv\\python.exe -m uvicorn app.main:app --host 127.0.0.1 --port 8000",
    "dev:frontend": "npm --prefix frontend run dev",
    "install:frontend": "npm --prefix frontend install"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "playwright": "^1.60.0"
  }
}
